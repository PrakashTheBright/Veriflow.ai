# Environment Configuration
NODE_ENV=development

# =================================
# UI Testing Credentials (per environment)
# =================================

# SIT Environment
SIT_APP_URL=https://pf.pfsit.xyz/selectprism/login
SIT_APP_USERNAME=your-sit-username@example.com
SIT_APP_PASSWORD=your-sit-password

# UAT Environment
UAT_APP_URL=https://selectprism.pfuat.xyz/selectprism/login
UAT_APP_USERNAME=your-uat-username@example.com
UAT_APP_PASSWORD=your-uat-password

# Production Environment
PROD_APP_URL=https://pf.prismforce.com/selectprism/login
PROD_APP_USERNAME=your-prod-username@example.com
PROD_APP_PASSWORD=your-prod-password

# Default credentials (fallback)
APP_URL=https://your-app-url.com/login
APP_USERNAME=your-username@example.com
APP_PASSWORD=your-password

# =================================
# API Testing Credentials (per environment)
# =================================

# SIT API
SIT_API_BASE_URL=https://api.pfsit.xyz
SIT_API_KEY=your-sit-api-key
SIT_API_CLIENT_ID=your-sit-client-id

# UAT API
UAT_API_BASE_URL=https://api.pfuat.xyz
UAT_API_KEY=your-uat-api-key
UAT_API_CLIENT_ID=your-uat-client-id

# Production API
PROD_API_BASE_URL=https://api.prismforce.com
PROD_API_KEY=your-prod-api-key
PROD_API_CLIENT_ID=your-prod-client-id

# =================================
# Browser Configuration
# =================================
BROWSER_HEADLESS=false
BROWSER_SLOW_MO=50
BROWSER_TIMEOUT=30000

# =================================
# Agent Configuration
# =================================
AGENT_AUTO_APPROVE=false
AGENT_MAX_RETRIES=3
AGENT_RETRY_DELAY=1000
AGENT_KEEP_BROWSER_OPEN=false

# =================================
# Logging
# =================================
LOG_LEVEL=info
LOG_FORMAT=json

# =================================
# Paths
# =================================
CREDENTIALS_PATH=./credentials/credentials.json
ACTIONS_PATH=./test-cases/approved
REPORTS_OUTPUT_PATH=./reports/output
