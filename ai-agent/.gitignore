# Dependencies
node_modules/

# Build output
dist/

# Environment files
.env
.env.local
.env.example

# Shared state (API test data)
.shared-state.json

# Credentials (NEVER commit)
credentials/*.json
credentials/*.yaml
!credentials/.gitkeep

# Logs
logs/*.log
logs/*.json

# Reports (optional - may want to keep)
reports/output/*
!reports/output/.gitkeep

# Screenshots (generated during test runs)
reports/screenshots/*
!reports/screenshots/.gitkeep

# Test results
test-results/*
!test-results/.gitkeep

# UI server/frontend logs
veriflow-ui/frontend_log.txt
veriflow-ui/server_log.txt

# IDE
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/

# Temporary files
*.tmp
*.temp
*.txt
tmp_*.js
.testcase-history.json
veriflow-ui/.testcase-history.json
