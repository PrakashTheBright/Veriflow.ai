{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Run Agent",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/src/index.ts",
      "args": ["test-cases/approved/login-flow.yaml"],
      "runtimeArgs": ["-r", "ts-node/register"],
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Run Agent (Headless)",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/src/index.ts",
      "args": ["test-cases/approved/login-flow.yaml", "--headless"],
      "runtimeArgs": ["-r", "ts-node/register"],
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development",
        "BROWSER_HEADLESS": "true"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Current Test Case",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}/src/index.ts",
      "args": ["${file}"],
      "runtimeArgs": ["-r", "ts-node/register"],
      "console": "integratedTerminal",
      "env": {
        "NODE_ENV": "development",
        "LOG_LEVEL": "debug"
      }
    }
  ]
}
