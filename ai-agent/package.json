{
  "name": "ai-web-automation-agent",
  "version": "1.0.0",
  "description": "VS Code-based AI agent for web application automation with Playwright",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test:run": "ts-node src/index.ts test-cases/approved/full-assessment-flow.md",
    "clean": "rimraf dist logs/*.log reports/output/*.html reports/output/*.json reports/screenshots/*",
    "clean:all": "npm run clean && rimraf node_modules",
    "lint": "eslint src/**/*.ts",
    "test": "jest"
  },
  "keywords": [
    "automation",
    "playwright",
    "ai-agent",
    "testing"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "chalk": "^4.1.2",
    "dotenv": "^16.3.1",
    "handlebars": "^4.7.8",
    "inquirer": "^8.2.6",
    "playwright": "^1.40.0",
    "uuid": "^9.0.1",
    "winston": "^3.11.0",
    "yaml": "^2.3.4",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.0",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "rimraf": "^6.1.2",
    "ts-jest": "^29.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
